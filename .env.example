# ============================================================================
# AI Agent Configuration
# Copy this file to .env and fill in your API keys
# ============================================================================

# ============================================================================
# FREE MODE (DEFAULT: ON)
# When true, the router ONLY uses $0 providers. You will never be charged.
# Set to false when you're ready to use credit-based/paid providers.
# ============================================================================
FREE_MODE=true

# ============================================================================
# 100% FREE PROVIDERS (no spend, ever)
# These have genuine free tiers with no credit card required
# ============================================================================

# Groq -- 30 RPM, ~1K req/day, fastest open-source inference
# Signup: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here

# Google Gemini -- 15 RPM, 250K TPM, all models free
# Signup: https://aistudio.google.com (click "Get API key" in sidebar)
GOOGLE_API_KEY=your-google-api-key-here

# Cerebras -- Free tier, fastest inference on earth
# Signup: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your-cerebras-key-here

# OpenRouter -- 20 RPM, 50 req/day on :free models
# Signup: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# Mistral -- 1 RPS, 500K TPM, ~1B tokens/mo free
# Signup: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-key-here

# Cohere -- 1000 calls/mo, 20 RPM (trial key, non-commercial)
# Signup: https://dashboard.cohere.com/welcome/register
COHERE_API_KEY=your-cohere-key-here

# Ollama -- Unlimited, runs on your own machine
# Install: https://ollama.ai then run: ollama serve
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# CREDIT-BASED PROVIDERS (free until credits run out)
# These give signup credits but charge after that
# Blocked by default when FREE_MODE=true
# ============================================================================

# DeepSeek -- No free credits, but extremely cheap ($0.14/$0.28 per 1M tokens)
# Signup: https://platform.deepseek.com/apikeys
DEEPSEEK_API_KEY=your-deepseek-key-here

# xAI (Grok) -- $25 signup credit; $150/mo if you opt into data sharing
# Signup: https://console.x.ai
XAI_API_KEY=your-xai-key-here

# Anthropic (Claude) -- $5 signup credit then paid
# Signup: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenAI -- 3 RPM free (very limited), then $5 minimum top-up
# Signup: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Together AI -- NO free tier, $5 minimum purchase required
# Signup: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your-together-key-here

# ============================================================================
# BUDGET SAFETY NET
# Even with FREE_MODE=false, these caps prevent runaway spending
# ============================================================================
DAILY_BUDGET_LIMIT=0.50
MONTHLY_BUDGET_LIMIT=5.00

# ============================================================================
# MEMORY & KNOWLEDGE
# ============================================================================
MEMORY_MAX_HISTORY=20
USE_EMBEDDINGS=true
# KNOWLEDGE_DIR=./knowledge
# AGENT_DB_PATH=./agent_data.db
